# Mise environment variables
# Copy to .env and fill in. NEVER commit real keys.

# Supabase project (Project Settings -> API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI Gateway — a server-side endpoint (Supabase Edge Function or Netlify function)
# that holds the real model provider key. The app NEVER talks to a model
# provider directly; it calls this gateway. See src/services/ai/README in code comments.
EXPO_PUBLIC_AI_GATEWAY_URL=https://your-project.functions.supabase.co/ai
